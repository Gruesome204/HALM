    <ui:VisualElement name="mainContainer" picking-mode="Ignore" class="mainContainerClass SlideIn pauseMenuBcakground" style="flex-direction: column; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; width: 40%; justify-content: flex-start;">
        <ui:Label text="Label" name="pauseMenuHeadline" class="sub-headline" style="align-self: center; white-space: normal; margin-bottom: 20%;" />
        <ui:VisualElement name="buttonContainer" style="height: auto; width: 100%; flex-shrink: 0; align-items: center; justify-content: center;">
            <ui:Button text="Button" name="resumeButton" class="paperButton" />
            <ui:Button text="Button" focusable="false" name="statsMenuButton" class="paperButton" />
            <ui:Button text="Button" name="settingsButton" class="paperButton" />
            <ui:Button text="Button" name="cancelRunButton" class="paperButton" />
            <ui:Button text="Button" name="mainMenuButton" class="paperButton" />
            <ui:Button text="Button" name="exitButton" class="paperButton" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
